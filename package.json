{
  "name": "cloud-mail-flare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node ./scripts/prebuild-clean.mjs",
    "telegram:webhook": "node ./scripts/telegram-webhook.mjs",
    "telegram:webhook:set": "node ./scripts/telegram-webhook.mjs set",
    "telegram:webhook:delete": "node ./scripts/telegram-webhook.mjs delete",
    "telegram:webhook:info": "node ./scripts/telegram-webhook.mjs info",
    "telegram:commands": "node ./scripts/telegram-webhook.mjs commands",
    "cf:mail-domain:setup": "node ./scripts/cloudflare-domain-setup.mjs",
    "smoke:api-key:v1": "node ./scripts/smoke-api-key-v1.mjs",
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build && node ./scripts/postbuild-add-email-handler.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "cf:dev": "pnpm build && pnpm exec wrangler dev",
    "deploy": "pnpm build && pnpm exec wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260402.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.18.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.2",
    "typescript": "^5.8.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "postal-mime": "^2.7.4",
    "sweetalert2": "^11.26.24"
  }
}
